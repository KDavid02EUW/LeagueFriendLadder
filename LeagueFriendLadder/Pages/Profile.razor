@if (isRateLimited)
{ //TODO ITT REFRESH PAGE
    <div class="rate-limit-overlay">
        <div class="rate-limit-content">
            <div class="hourglass-anim">⏳</div>
            <h2 style="color: black; font-weight: bold;">Wait a minute!</h2>
            <p style="color: black;">The Riot servers are getting too many requests.</p>

            <div class="countdown-display" style="color: #d71919; font-weight: bold;">
                Retry in:
                <strong>
                    @(countdownValue / 60):@(countdownValue % 60 < 10 ? "0" : "")@(countdownValue % 60)
                </strong>
            </div>

            <div class="progress mt-3" style="height: 12px; background-color: rgba(255,255,255,0.1); border-radius: 6px; overflow: hidden;">
                <div class="progress-bar bg-dark" role="progressbar"
                     style="width: @( (double)countdownValue / maxCountdownValue * 100 )%; transition: width 1s linear;">
                </div>
            </div>

            <button class="btn btn-outline-primary mt-4" @onclick="() => isRateLimited = false">
                Close
            </button>
        </div>
    </div>
}
@code {
    [Parameter] public string? SummonerName { get; set; }
    [Parameter] public string? Tag { get; set; }
    private LeagueEntryDTO? player;
    private List<MatchDTO>? matches;
    private RiotAccount? riotAccount;
    private string? currentRegion;
    private bool isRateLimited = false;
    private int countdownValue = 0;
    private int maxCountdownValue = 120;
    private Timer? rateLimitTimer;
    private Dictionary<int, ArenaAugment> augmentDict = new();


    private HashSet<string> expandedMatches = new HashSet<string>();

    protected override async Task OnInitializedAsync()
    {
        player = await Session.GetPlayerAsync();
        await LoadAugmentsAsync();



        if (player == null)
        {
            await Task.Delay(2000);
            Nav.NavigateTo("ListPlayers");
        } else
        {
            await LoadMatchesSafe();
        }
    }
    private async Task LoadAugmentsAsync()
    {
        try
        {
            var root = await Http.GetFromJsonAsync<ArenaAugmentRoot>("data/augments.json");

            if (root?.Augments != null)
            {
                augmentDict = root.Augments
                    .Where(a => a.Id > 0)
                    .GroupBy(a => a.Id)
                    .ToDictionary(g => g.Key, g => g.First());
            }
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
        {
            Console.WriteLine("Error: File not found");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading augments: {ex.Message}");
        }
    }
    protected override async Task OnParametersSetAsync()
    {
        matches = null;
        player = await Session.GetPlayerAsync();
        try
        {
            if (player == null || player.SummonerName != SummonerName || player.Tag != Tag)
            {
                string riotId = SummonerName + "#" + Tag;
                var fetchedAccount = await RiotService.GetRiotID(riotId);

                if (fetchedAccount != null)
                {
                    player = new LeagueEntryDTO
                        {
                            SummonerName = SummonerName,
                            Tag = Tag,
                            Puuid = fetchedAccount.Puuid
                        };
                }
                else
                {
                    Nav.NavigateTo("ListPlayers");
                    return;
                }
            }

            if (player != null)
            {
                currentRegion = player.Region;
                await LoadMatchesSafe();
            }
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.TooManyRequests)
        {
            await StartCountdown(120);
        }
    }
    private async Task LoadMatchesSafe()
    {
        try
        {
            if (player != null)
            {
                matches = await RiotService.getMatchesByPuuid(player.Puuid);
            }
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.TooManyRequests)
        {
            await StartCountdown(120);
        }
    }
    private void NavigateToPlayer(string name, string tag)
    {

        Nav.NavigateTo($"/profile/{name}/{tag}");
    }
    private void ToggleMatchDetails(string matchId)
    {
        if (expandedMatches.Contains(matchId))
        {
            expandedMatches.Remove(matchId);
        }
        else
        {
            expandedMatches.Add(matchId);
        }
    }
    public static string GetSummonerSpellName(int spellId) => spellId switch
    {
        1 => "SummonerBoost",
        3 => "SummonerExhaust",
        4 => "SummonerFlash",
        6 => "SummonerHaste",
        7 => "SummonerHeal",
        11 => "SummonerSmite",
        12 => "SummonerTeleport",
        14 => "SummonerDot",
        21 => "SummonerBarrier",
        32 => "SummonerSnowball",
        _ => "SummonerEmpty"
    };
    private string GetPositionName(string position) => position?.ToLower() switch
    {
        "top" => "top",
        "jungle" => "jungle",
        "middle" => "middle",
        "bottom" => "bottom",
        "utility" => "utility",
        _ => "none",
    };
    private async Task StartCountdown(int seconds)
    {
        countdownValue = seconds;
        maxCountdownValue = seconds;
        isRateLimited = true;

        rateLimitTimer?.Stop();
        rateLimitTimer?.Dispose();

        rateLimitTimer = new Timer(1000);
        rateLimitTimer.Elapsed += (sender, e) =>
        {
            if (countdownValue > 0)
            {
                countdownValue--;
                InvokeAsync(StateHasChanged);
            }
            else
            {
                rateLimitTimer.Stop();
                isRateLimited = false;

                InvokeAsync(() =>
                {
                    Nav.NavigateTo(Nav.Uri, forceLoad: true);
                });
            }
        };
        rateLimitTimer.Start();
    }
}