@page "/Profile/{SummonerName}/{Tag}"
@using System.Globalization
@using LeagueFriendLadder.Models
@using Microsoft.AspNetCore.Components
@using System.Timers
@using System.Text.Json
@using static System.Net.WebRequestMethods
@inject RiotService RiotService
@inject LeagueFriendLadder.Services.PlayerSessionService Session
@inject NavigationManager Nav
@inject HttpClient Http

<PageTitle>Profile - @(SummonerName ?? "Loading...")</PageTitle>

@if (player == null)
{
    <div class="alert alert-warning">
        No user selected. Redirecting to the list...
        <progress id="progress-2"></progress>
    </div>
}
else
{
    <main>
        <div id="history">
            @if (matches == null)
            {
                <div class="d-flex justify-content-center">
                    <div class="spinner-border" role="status"></div>
                    <span class="ms-2">Loading matches...</span>
                    <progress id="progress-2"></progress>
                </div>
            }
            else
            {
                <table class="table-history">    
                    <thead>
                        <tr>
                            <th colspan="100%">Last 20 games of @player.SummonerName</th>
                        </tr>
                        <tr>
                            <th>Champion</th>
                            <th>Result</th>
                            <th>KDA</th>
                            <th>Items</th>
                            <th>Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var match in matches)
                        {
                            string currentChamp = "";
                            bool isWin = false;
                            string kda = "";
                            int kills = 0;
                            int deaths = 0;
                            int assists = 0;
                            int champLevel = 0;
                            int spell1 = 0;
                            int spell2 = 0;
                            string position = "";
                            int item0 = 0;
                            int item1 = 0;
                            int item2 = 0;
                            int item3 = 0;
                            int item4 = 0;
                            int item5 = 0;
                            int item6 = 0;
                            int playerAugment1 = 0;
                            int playerAugment2 = 0;
                            int playerAugment3= 0;
                            int playerAugment4 = 0;
                            DateTime date = DateTimeOffset.FromUnixTimeMilliseconds(match.gameEndTimeStamp).DateTime;

                            foreach (var participant in match.Participants)
                            {
                                if (participant.riotIDGameName == player.SummonerName && participant.riotIDTagLine == player.Tag)
                                {
                                    currentChamp = participant.championName;
                                    isWin = participant.win;
                                    kills = participant.kills;
                                    deaths = participant.deaths;
                                    assists = participant.assists;
                                    champLevel = participant.champLevel;
                                    spell1 = participant.summoner1ID;
                                    spell2 = participant.summoner2ID;
                                    position = participant.teamPosition;
                                    item0 = participant.item0;
                                    item1 = participant.item1;
                                    item2 = participant.item2;
                                    item3 = participant.item3;
                                    item4 = participant.item4;
                                    item5 = participant.item5;
                                    item6 = participant.item6;
                                    playerAugment1 = participant.playerAugment1;
                                    playerAugment2 = participant.playerAugment2;
                                    playerAugment3 = participant.playerAugment3;
                                    playerAugment4 = participant.playerAugment4;
                                    


                                    if (participant.deaths == 0)
                                    {
                                        kda = "Perfect";
                                    }
                                    else
                                    {
                                        kda = RiotService.getKDA(kills, deaths, assists);
                                    }
                                }
                            }

                            bool isExpanded = expandedMatches.Contains(match.MatchID);

