@page "/"
@using System.ComponentModel.DataAnnotations
@using LeagueFriendLadder.Models
@inject HttpClient Http
@inject RiotService riotService

<PageTitle>Home</PageTitle>

<!--TODO LOGIN ÁTIRÁNYÍTÁS-->

<EditForm Model="RiotID" OnValidSubmit="getRiotID">
    <div class="form-style-container">
        <div class="form-style-content">
			<DataAnnotationsValidator />
			
            <label>Summoner Name#Tag</label>
			<InputText @bind-Value="RiotID.SummonerName"></InputText>
			<label>Region</label>
			<InputSelect @bind-Value="RiotID.Region">
				<option value="">Select your region</option>
				<option value="BR1">BR</option>
				<option value="EUN1">EUNE</option>
				<option value="EUW1">EUW</option>
				<option value="JP1">JP</option>
				<option value="KR">KR</option>
				<option value="LA1">LAN</option>
				<option value="LA2">LAS</option>
				<option value="ME1">ME</option>
				<option value="NA1">NA</option>
				<option value="OC1">OCE</option>
				<option value="RU">RU</option>
				<option value="SG2">SG</option>
				<option value="TR1">TR</option>
				<option value="TW2">TW</option>
				<option value="VN2">VN</option>
			</InputSelect>
			<br /><br />
			<button type="submit" href="#target">Search</button>
        </div>
    </div>
    <br />
    <ValidationSummary />
</EditForm>

@if (!string.IsNullOrEmpty(errorMessage) && !isLoading && hasSearched)
{
    <br />
    <strong>Summoner Not Found</strong>
    <br />
    <strong>Name:</strong> @RiotID.SummonerName
    <br />
    <strong>Region:</strong> @RiotID.Region
    <br />
    <p style="color:red">
        @errorMessage
    </p>
}
else if (result != null && result2 != null)
{
    <table>
        <thead>
            <th>Summoner Name</th>
            <th>Tag</th>
            <th>Queue Type</th>
            <th>Tier</th>
            <th>Rank</th>
            <th>LP</th>
            <th>Wins</th>
            <th>Losses</th>
            <th>Winrate</th>
            <th>Hotstreak</th>
        </thead>
        <tbody class="single-view" id="target">
            <td><a @onclick="() => riotService.viewProfile(result2)">@result.GameName</a></td>
            <td>@result.TagLine</td>
            <td>@result2.QueueType</td>
            <td>@result2.Tier</td>
            <td>@result2.Rank</td>
            <td>@result2.LeaguePoints</td>
            <td>@result2.Wins</td>
            <td>@result2.Losses</td>
            <td>@result2.Winrate%</td>
            <td>@result2.HotStreak</td>
        </tbody>
    </table>
}
else if (result != null && result2 == null)
{
    <table>
        <thead>
        <th>Summoner Name</th>
        <th>Tag</th>
        <th>Rank</th>
        </thead>
        <tbody class="single-view">
        <td>@result.GameName</td>
        <td>@result.TagLine</td>
        <td>Unranked</td>
        </tbody>
    </table>
}
else if(!isLoading && result != null && unranked)
{
    <br /><strong>Name:</strong>
 
    @RiotID.SummonerName
	<br />
	<p><strong>Tag:</strong> @result.TagLine</p>
	<br />
    <strong>Region:</strong>
    @RiotID.Region    
    <p style="color:red">
        @errorMessage
    </p>
}
else if (!isLoading && result == null && result2 == null && hasSearched)
{
    <br />
    <strong>Summoner Not Found</strong>
    <br />
    <strong>Name:</strong> @RiotID.SummonerName
    <br />
    <strong>Region:</strong> @RiotID.Region
    <br />
    <p style="color:red">
        @errorMessage
    </p>
}
@if (isLoading)
{
    <br />
    <p><strong>Loading...</strong><progress id="progress-2"></progress></p>
}



@code {

    private bool hasSearched = false;
    private bool isLoading = false;
    private bool unranked = false;
    private RiotID RiotID = new();
    private RiotAccount? result;
    private LeagueEntryDTO? result2;
    private string? errorMessage;
    string apiKey = "RGAPI-15de7229-e9c5-49f8-a1d0-69a63a7bb4ab";

    public async Task getRiotID()
    {
        hasSearched = true;
        isLoading = true;
        result = null;
        result2 = null;
        errorMessage = null;
        try
        {
            var parts = RiotID.SummonerName.Split("#");
            if (parts.Length < 2)
            {
                errorMessage = "Invalid Summoner Name format. Use [Name#Tag].";
                return;
            }

            var summonerName = parts[0];
            var tag = parts[1];

            var url = $"https://europe.api.riotgames.com/riot/account/v1/accounts/by-riot-id/{summonerName}/{tag}?api_key={apiKey}";

            result = await Http.GetFromJsonAsync<RiotAccount>(url);

            if (result != null)
            {
                var puuid = result.Puuid;
                await getSummonerDetailsByPuuID(puuid);
            }

            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
            result = null;
        }
        finally
        {
            isLoading = false;
            hasSearched = true;
        }
    }

    private async Task getSummonerDetailsByPuuID(string puuid)
    {

        try
        {
            var url = $"https://{RiotID.Region.ToLower()}.api.riotgames.com/lol/league/v4/entries/by-puuid/{puuid}?api_key={apiKey}";

            var response = await Http.GetFromJsonAsync<List<LeagueEntryDTO>>(url);

            if (response != null)
            {
                foreach (var resp in response)
                {

                    if (resp.Puuid != null)
                    {
                        result2 = resp;
                        double games = result2.Wins + result2.Losses;
                        double wins = result2.Wins;
                        double losses = result2.Losses;
                        result2.Puuid = result.Puuid;
                        result2.Tag = result.TagLine;
                        result2.SummonerName = result.GameName;

                        result2.Winrate = riotService.getWinrate(resp);
                        errorMessage = null;
                    }
                    else if (puuid != null && resp == null)
                    {
                        result2 = resp;
                        unranked = true;
                        errorMessage = null;
                    }
                    
                }
                
            } else
            {
                errorMessage = $"Error: Summoner not found for the selected region: [{RiotID.Region}]";
                result = null;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
            result2 = null;
        }
    }
}
