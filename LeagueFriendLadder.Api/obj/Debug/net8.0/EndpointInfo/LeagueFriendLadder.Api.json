{
  "openapi": "3.0.1",
  "info": {
    "title": "LeagueFriendLadder.Api",
    "version": "1.0"
  },
  "paths": {
    "/api/Summoner/save": {
      "post": {
        "tags": [
          "Summoner"
        ],
        "parameters": [
          {
            "name": "tag",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "region",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LeagueEntryDTO"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LeagueEntryDTO"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LeagueEntryDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Summoner/{puuid}": {
      "get": {
        "tags": [
          "Summoner"
        ],
        "parameters": [
          {
            "name": "puuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Summoner/ladder": {
      "get": {
        "tags": [
          "Summoner"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "LeagueEntryDTO": {
        "type": "object",
        "properties": {
          "queueType": {
            "type": "string",
            "nullable": true
          },
          "puuid": {
            "type": "string",
            "nullable": true
          },
          "summonerName": {
            "type": "string",
            "nullable": true
          },
          "tag": {
            "type": "string",
            "nullable": true
          },
          "tier": {
            "type": "string",
            "nullable": true
          },
          "rank": {
            "type": "string",
            "nullable": true
          },
          "leaguePoints": {
            "type": "integer",
            "format": "int32"
          },
          "wins": {
            "type": "integer",
            "format": "int32"
          },
          "losses": {
            "type": "integer",
            "format": "int32"
          },
          "hotStreak": {
            "type": "boolean"
          },
          "winrate": {
            "type": "number",
            "format": "double"
          },
          "region": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}